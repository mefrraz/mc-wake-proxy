# mc-wake-proxy environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ---- Required: Wake-on-LAN ----
WOL_MAC=c4:34:6b:60:40:9b
WOL_BROADCAST=192.168.1.255

# ---- Required: Minecraft backend ----
BACKEND_TARGET=192.168.1.131:25565

# ---- Required: Proxmox VE API ----
PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_NODE=pve
PROXMOX_LXC_ID=100
# Create this token in Proxmox UI → Datacenter → Permissions → API Tokens
# See docs/proxmox-setup.md for step-by-step instructions
PROXMOX_TOKEN_ID=root@pam!mc-wake-proxy
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_INSECURE_SKIP_VERIFY=true

# ---- Required: Crafty Controller API ----
CRAFTY_HOST=192.168.1.131
CRAFTY_PORT=8443
CRAFTY_SCHEME=https
# Create this token in Crafty → username menu → API Tokens
# See docs/crafty-setup.md for step-by-step instructions
CRAFTY_TOKEN=your-crafty-api-token-here
# Find this in Crafty → click your server → look at the URL: .../panel/server_detail?id=THIS
CRAFTY_SERVER_ID=your-server-uuid-here
CRAFTY_INSECURE_SKIP_VERIFY=true

# ---- Optional: tuning ----
MC_LISTEN_PORT=25565
WEB_PORT=8080
LANG=en
COOLDOWN_MINUTES=5
